    // Focus card from sidebar
    private async Task FocusCardInBoard(TodoInfo todoInfo)
    {
        if (todoInfo.IsBoardLevel) return;

        // Expand the card if collapsed
        collapsedCardIds.Remove(todoInfo.CardId);

        // If the card is completed but we're hiding completed, show completed cards
        var card = board?.Lanes.SelectMany(l => l.Cards).FirstOrDefault(c => c.Id == todoInfo.CardId);
        if (card is { IsCompleted: true } && !showCompleted)
        {
            showCompleted = true;
        }

        // Set focused card for highlight
        focusedCardId = todoInfo.CardId;

        // Re-render, then scroll
        StateHasChanged();
        await Task.Yield();
        await JS.InvokeVoidAsync("scrollToCard", $"card-{todoInfo.CardId}");

        // Clear the highlight after animation
        _ = ClearFocusAfterDelay();
    }

    private async Task ClearFocusAfterDelay()
    {
        await Task.Delay(2000);
        focusedCardId = null;
        StateHasChanged();
    }

    // Notes methods
    private bool IsNotesExpanded(Guid cardId) => expandedNotesCardIds.Contains(cardId);

    private void ToggleNotesExpand(Guid cardId)
    {
        if (expandedNotesCardIds.Contains(cardId))
        {
            expandedNotesCardIds.Remove(cardId);
        }
        else
        {
            expandedNotesCardIds.Add(cardId);
            // Initialize cache with current notes
            var card = board?.Lanes.SelectMany(l => l.Cards).FirstOrDefault(c => c.Id == cardId);
            if (card != null)
            {
                notesTextCache[cardId] = card.Notes;
            }
        }
    }

