    // Sidebar todo methods
    private IEnumerable<TodoInfo> GetAllActiveTodos()
    {
        if (board == null) return Enumerable.Empty<TodoInfo>();

        // Board-level todos
        var boardTodos = board.Todos
            .Where(todo => !todo.IsCompleted)
            .Select(todo => new TodoInfo(todo, Guid.Empty, "", Guid.Empty, "", true));

        // Card-level todos
        var cardTodos = board.Lanes
            .SelectMany(lane => lane.Cards
                .SelectMany(card => card.Todos
                    .Where(todo => !todo.IsCompleted)
                    .Select(todo => new TodoInfo(todo, lane.Id, lane.Name, card.Id, card.Title, false))));

        return boardTodos.Concat(cardTodos).OrderByDescending(t => t.Todo.CreatedAt);
    }

    private IEnumerable<TodoInfo> GetSidebarTodos()
    {
        if (board == null) return Enumerable.Empty<TodoInfo>();

        // Board-level todos
        var boardTodos = board.Todos
            .Where(todo => showCompletedTodos || !todo.IsCompleted)
            .Select(todo => new TodoInfo(todo, Guid.Empty, "", Guid.Empty, "", true));

        // Card-level todos
        var cardTodos = board.Lanes
            .SelectMany(lane => lane.Cards
                .SelectMany(card => card.Todos
                    .Where(todo => showCompletedTodos || !todo.IsCompleted)
                    .Select(todo => new TodoInfo(todo, lane.Id, lane.Name, card.Id, card.Title, false))));

        return boardTodos.Concat(cardTodos)
            .OrderBy(t => t.Todo.IsCompleted)
            .ThenByDescending(t => t.Todo.IsTodaysTodo && !t.Todo.IsCompleted)
            .ThenByDescending(t => t.Todo.CreatedAt);
    }

