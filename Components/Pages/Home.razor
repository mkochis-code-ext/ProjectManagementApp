        {
            expandedLinksCardIds.Remove(cardId);
            if (addingLinkForCardId == cardId)
            {
                CancelAddLink();
            }
        }
        else
        {
            expandedLinksCardIds.Add(cardId);
        }
    }

    private void StartAddLink(Guid cardId)
    {
        addingLinkForCardId = cardId;
        newLinkTitle = "";
        newLinkUrl = "";
    }

    private void CancelAddLink()
    {
        addingLinkForCardId = null;
        newLinkTitle = "";
        newLinkUrl = "";
    }

    private async Task HandleLinkKeyDown(KeyboardEventArgs e, Guid laneId, Guid cardId)
    {
        if (e.Key == "Enter")
        {
            await AddLink(laneId, cardId);
        }
        else if (e.Key == "Escape")
        {
            CancelAddLink();
        }
    }

    private async Task AddLink(Guid laneId, Guid cardId)
    {
        if (!string.IsNullOrWhiteSpace(newLinkUrl) && board != null)
        {
            await BoardService.AddCardLinkAsync(board.Id, laneId, cardId, newLinkTitle.Trim(), newLinkUrl.Trim());
            board = await BoardService.GetBoardAsync(board.Id);
            CancelAddLink();
        }
    }

    private async Task DeleteLink(Guid laneId, Guid cardId, Guid linkId)
    {
        if (board != null)
        {
            await BoardService.DeleteCardLinkAsync(board.Id, laneId, cardId, linkId);
            board = await BoardService.GetBoardAsync(board.Id);
        }
    }

    // Quick add todo methods
    private bool HasAvailableCards()
    {
        return board?.Lanes.Any(l => l.Cards.Any()) ?? false;
    }

    private bool IsBoardLevelTodo()
    {
        return quickTodoLaneId == Guid.Empty && quickTodoCardId == Guid.Empty;
    }

    private bool IsPartialSelection()
    {
        return (quickTodoLaneId != Guid.Empty && quickTodoCardId == Guid.Empty) ||
               (quickTodoLaneId == Guid.Empty && quickTodoCardId != Guid.Empty);
    }

    private string GetSelectedCardName()
    {
        if (board == null || quickTodoCardId == Guid.Empty) return "";
        var lane = board.Lanes.FirstOrDefault(l => l.Id == quickTodoLaneId);
        var card = lane?.Cards.FirstOrDefault(c => c.Id == quickTodoCardId);
        return card?.Title ?? "";
    }

    private void ShowQuickAddTodoPanel()
    {
        quickTodoLaneId = Guid.Empty;
        quickTodoCardId = Guid.Empty;
        quickTodoText = "";
        showQuickTodoValidation = false;
        showQuickAddTodoPanel = true;
    }

    private void CloseQuickAddTodoPanel()
    {
        showQuickAddTodoPanel = false;
        showQuickTodoValidation = false;
    }

    private void OnQuickTodoLaneChanged()
    {
        quickTodoCardId = Guid.Empty;
    }

    private async Task HandleQuickAddTodoKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await AddQuickTodo();
        }
        else if (e.Key == "Escape")
        {
            CloseQuickAddTodoPanel();
        }
    }

    private async Task AddQuickTodo()
    {
        showQuickTodoValidation = true;
        if (string.IsNullOrWhiteSpace(quickTodoText) || board == null)
        {
            return;
        }

        // Validate: must select both lane and card, or neither (for board-level)
        if (IsPartialSelection())
        {
            return;
        }

        if (IsBoardLevelTodo())
        {
            // Add as board-level todo
            await BoardService.AddBoardTodoAsync(board.Id, quickTodoText.Trim());
        }
        else
        {
            // Add as card-level todo
            await BoardService.AddTodoAsync(board.Id, quickTodoLaneId, quickTodoCardId, quickTodoText.Trim());
        }
        
        board = await BoardService.GetBoardAsync(board.Id);
        CloseQuickAddTodoPanel();
    }

    // Backup method
    private async Task BackupData()
    {
        try
        {
            if (File.Exists(dataFilePath))
            {
                var documentsPath = Environment.GetFolderPath(Environment.SpecialFolder.MyDocuments);
                var dateStamp = DateTime.Now.ToString("yyyyMMddHHmmss");
                var backupFileName = $"BoardCollection-{dateStamp}.json";
                var backupPath = Path.Combine(documentsPath, backupFileName);
                
                await File.WriteAllTextAsync(backupPath, await File.ReadAllTextAsync(dataFilePath));
                
                backupMessage = $"Backup saved: {backupFileName}";
                backupSuccess = true;
            }
            else
            {
                backupMessage = "No data file to backup";
                backupSuccess = false;
            }
        }
        catch (Exception ex)
        {
            backupMessage = $"Backup failed: {ex.Message}";
            backupSuccess = false;
        }
        
        StateHasChanged();
        await Task.Delay(3000);
        backupMessage = "";
        StateHasChanged();
    }
}
